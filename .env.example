# ============================================================
# AI SAGLAYICI AYARLARI (saglayicidan bagimsiz)
# ------------------------------------------------------------
# Herhangi bir OpenAI-uyumlu saglayici calisir. Sadece bu uc
# degeri degistir: anahtar, taban URL ve model.
#
#   AI_API_KEY   -> saglayicinin API anahtari
#   AI_BASE_URL  -> saglayicinin OpenAI-uyumlu taban URL'i
#   AI_MODEL     -> kullanilacak model adi
#
# Ornek yapilandirmalar (birini sec, digerlerini sil/yorumla):
#
#   # OpenAI (varsayilan)
#   AI_API_KEY=sk-...
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_MODEL=gpt-4.1-mini
#
#   # Anthropic (OpenAI-uyumlu uc nokta)
#   AI_API_KEY=sk-ant-...
#   AI_BASE_URL=https://api.anthropic.com/v1
#   AI_MODEL=claude-sonnet-4-6
#
#   # Diger 3. parti / yerel (OpenRouter, Groq, Together, Ollama vb.)
#   AI_API_KEY=...
#   AI_BASE_URL=https://ornek-saglayici/v1
#   AI_MODEL=saglayicinin-model-adi
#
# Not: AI_BASE_URL bos birakilirsa varsayilan OpenAI kullanilir.
# Standart OPENAI_API_KEY degiskeni de anahtar olarak kabul edilir.
# ============================================================
AI_API_KEY=sk-your_key_here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# Tarih/saat hesaplari icin saat dilimi
TIMEZONE=Europe/Istanbul

# Tek mesaj icin karakter siniri
MAX_INPUT_CHARS=8000

# Hafizaya beslenecek son mesaj sayisi (sohbet hafizasi)
HISTORY_WINDOW=25

# Telegram bot token (@BotFather'dan alinir). CLI icin gerekli degil.
TELEGRAM_BOT_TOKEN=

# Telegram'da sadece bu kullanici ID'lerinin botu kullanmasina izin ver (virgulle ayir).
# Bos birakilirsa herkes kullanabilir. Kendi ID'ni @userinfobot'tan ogrenebilirsin.
TELEGRAM_ALLOWED_IDS=

# (Istege bagli) Daha guvenilir web arama icin Brave Search API anahtari.
# Bos birakilirsa DuckDuckGo kullanilir. Ucretsiz anahtar: https://brave.com/search/api/
BRAVE_API_KEY=
